# 4.Problem Statement:
class Rectangle:

    def __init__(self, length, width):
        self.length = length
        self.width = width
    def area(self):
        return self.length * self.width

rect1 = Rectangle(10, 5)
print("Length:", rect1.length)
print("Width:", rect1.width)
print("Area of Rectangle:", rect1.area())



